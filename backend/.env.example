# Copy to .env. The app runs fully without these (rule-based + heuristic fallback).

# --- AI provider selection ---
# auto = Azure OpenAI when configured, else Gemini (default). Or force: gemini | azure
AI_PROVIDER=auto

# --- AI: Gemini (default / universal fallback) ---
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# --- AI: Azure OpenAI (lights up only when all three are set) ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# --- Database (SQLite now; swap for a Postgres URL — e.g. Azure Database for
#     PostgreSQL — later) ---
# postgresql+psycopg://user:pass@localhost:5432/linkedin_coach
DATABASE_URL=sqlite:///./linkedin_coach.db

# --- Artifact storage for generated PDF reports ---
# auto = Azure Blob when a connection string is set, else local filesystem.
ARTIFACT_STORE=auto
ARTIFACTS_DIR=var/artifacts
# Set to enable Azure Blob (also: pip install azure-storage-blob)
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=reports

# --- Compliant source fetching (GitHub API, portfolio sites, job postings) ---
# Optional GitHub token raises the API rate limit for /fetch.
GITHUB_TOKEN=
FETCH_TIMEOUT_SECONDS=10
FETCH_MAX_BYTES=3145728

# --- ML (Phase 2) ---
ML_MODEL_PATH=ml/model.pkl

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
